# ─────────────────────────────────────────────────────────────────
# .streamlit/secrets.toml  —  NEVER commit this file to GitHub
# Add each key in Streamlit Cloud → App Settings → Secrets
# ─────────────────────────────────────────────────────────────────

# Supabase
SUPABASE_URL = "https://xxxx.supabase.co"
SUPABASE_KEY = "your-supabase-anon-key"

# Razorpay
RAZORPAY_KEY_ID     = "rzp_live_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET = "your_razorpay_secret"

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID    = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN     = "your_twilio_auth_token"
TWILIO_WHATSAPP_FROM  = "whatsapp:+14155238886"   # Twilio sandbox or approved sender

# App URL (your Streamlit Cloud URL — no trailing slash)
APP_URL = "https://yourapp.streamlit.app"
